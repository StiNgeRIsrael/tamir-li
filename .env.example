# Copy to `.env.development.local` or `.env.production.local` (never commit secrets).
# Vite exposes only variables prefixed with VITE_.
#
# Production template (tamir.li on Plesk Node.js monolith) — copy into `.env.production.local`, then `npm run build`:
#   VITE_SITE_ORIGIN=https://tamir.li
#   VITE_API_URL=https://tamir.li
#   VITE_GTM_ID=GTM-XXXXXXX
#   VITE_ADSENSE_CLIENT=ca-pub-4410150504570814
#   VITE_PAYPAL_CLIENT_ID=your_sandbox_client_id

# Canonical site URL (SEO, canonical links, sitemap, hreflang).
# Local dev (copy this file to `.env.development.local` — see docs/local-dev.md):
# VITE_SITE_ORIGIN=http://localhost:8080
# VITE_API_URL=http://localhost:5000
# Production (tamir.li):
# VITE_SITE_ORIGIN=https://tamir.li

# Backend API origin (no trailing slash). Same origin for Plesk Node.js monolith:
# VITE_API_URL=https://tamir.li
# Separate API subdomain (legacy):
# VITE_API_URL=https://api.tamir.li

# In development, mock conversion UI is ON unless you set:
# VITE_USE_MOCK_CONVERSION=false
#
# In production builds, mock conversion is OFF unless you explicitly set:
# VITE_USE_MOCK_CONVERSION=true

# Google Identity Services (OAuth client ID — Web). Must match backend GOOGLE_CLIENT_ID.
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Google Tag Manager container ID (recommended — load GA4 + custom events via GTM).
# Do NOT also set VITE_GA4_ID when using GTM (avoids double counting).
# VITE_GTM_ID=GTM-5GH9HV38

# GA4 measurement ID — only if NOT using GTM (direct gtag.js). Configure GA4 inside GTM instead.
# VITE_GA4_ID=G-EBE6D6BPZ0

# Google AdSense (display ads only — site approval required)
# VITE_ADSENSE_CLIENT=ca-pub-4410150504570814
# VITE_ADSENSE_SLOT_BANNER=1234567890
# VITE_ADSENSE_SLOT_SIDEBAR=1234567891
# VITE_ADSENSE_SLOT_INLINE=1234567892
# VITE_ADSENSE_SLOT_INTERSTITIAL=1234567893
# VITE_ADSENSE_SLOT_ANCHOR=1234567894

# Popup URL for two-step download flow (first click opens this; second click downloads)
# VITE_AD_CLICK_URL=https://example.com/ad-landing

# PayPal client ID (optional — checkout uses server redirect; only needed for JS SDK buttons)
# VITE_PAYPAL_CLIENT_ID=your_sandbox_client_id

# Stripe publishable key (only if ENABLE_STRIPE=true on backend)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
