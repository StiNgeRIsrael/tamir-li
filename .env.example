# Copy to `.env.development.local` or `.env.production.local` (never commit secrets).
# Vite exposes only variables prefixed with VITE_.

# Canonical site URL (SEO, canonical links). Example production:
# VITE_SITE_ORIGIN=https://tamir.li

# Backend API origin (no trailing slash). Required for real conversions in production builds.
# VITE_API_URL=https://api.tamir.li

# In development, mock conversion UI is ON unless you set:
# VITE_USE_MOCK_CONVERSION=false
#
# In production builds, mock conversion is OFF unless you explicitly set:
# VITE_USE_MOCK_CONVERSION=true

# Google Identity Services (OAuth client ID — Web). Must match backend GOOGLE_CLIENT_ID.
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
