# Copy to `backend/.env` for local development (never commit secrets).
# Full guide: docs/local-dev.md
#
# Environment variables
# development | production
NODE_ENV=development

PORT=5000

# Prisma database connection URL (Replace with your actual MySQL connection string)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/tamirly_db"

# JWT Secret for authentication (min 16 characters in production)
JWT_SECRET="your_super_secret_jwt_key_here"

# Google Sign-In — OAuth 2.0 Client ID (Web application). Same value as VITE_GOOGLE_CLIENT_ID on the frontend.
GOOGLE_CLIENT_ID="123456789-xxxx.apps.googleusercontent.com"

# Allowed frontend origins (comma-separated), e.g. http://localhost:8080,https://tamir.li
CORS_ORIGIN="http://localhost:8080"

# Comma-separated emails that receive ADMIN on Google sign-in (first bootstrap / emergency access)
ADMIN_EMAILS="you@example.com"

# PayPal billing (primary — Israel)
PAYPAL_CLIENT_ID="your_sandbox_client_id"
PAYPAL_CLIENT_SECRET="your_sandbox_client_secret"
PAYPAL_WEBHOOK_ID="your_webhook_id"
PAYPAL_MODE="sandbox"
# Billing plan IDs from PayPal Dashboard → Subscriptions → Plans (P-...)
PAYPAL_PLAN_MONTHLY="P-..."
PAYPAL_PLAN_YEARLY="P-..."

# Stripe (optional — set ENABLE_STRIPE=true to use instead of PayPal)
# ENABLE_STRIPE=false
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_MONTHLY="price_..."
# STRIPE_PRICE_YEARLY="price_..."
# STRIPE_PRICE_CREDITS_10="price_..."
# STRIPE_PRICE_CREDITS_30="price_..."
# STRIPE_PRICE_CREDITS_60="price_..."
# STRIPE_PRICE_CREDITS_120="price_..."

# Server-side conversion queue (POST /api/conversions)
# Disk path for job input/output files (default: backend/data/conversions)
CONVERSION_STORAGE_DIR=
# Delete completed/failed/stale-pending jobs and files after this many hours (default: 24)
CONVERSION_JOB_TTL_HOURS=24
# Optional full path to ffmpeg binary for audio-converter jobs (default: ffmpeg on PATH)
FFMPEG_PATH=

# External APIs
OPENAI_API_KEY="sk-..."
RESEND_API_KEY="re_..."
