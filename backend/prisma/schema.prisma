generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  /** חסימת גישה לאתר (למשתמש מחובר) */
  blocked        Boolean          @default(false)
  /** המרות בונוס מעבר למכסה היומית החינמית — נצרכות אחרי 5 יומיות */
  bonusConversions Int            @default(0)
  /** סיסמה — רק למשתמשים שנרשמו עם אימייל/סיסמה; OAuth לא דורש */
  passwordHash   String?
  /** מזהה ייחודי מחשבון Google (sub בתוך ה-JWT של Google) */
  googleSub      String?          @unique
  profile        Profile?
  roles          UserRole[]
  subscription   Subscription?
  payments       Payment[]
  aiCredits         AiCredit?
  aiGenerationLogs  AiGenerationLog[]
  usageLogs         UsageLog[]
  conversionJobs    ConversionJob[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Profile {
  id          String   @id
  user        User     @relation(fields: [id], references: [id], onDelete: Cascade)
  displayName String?
  avatarUrl   String?
  locale      String   @default("he")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum RoleType {
  ADMIN
  MODERATOR
  USER
}

model UserRole {
  id     String   @id @default(uuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   RoleType

  @@unique([userId, role])
}

/** הגדרות פרסום Adsterra — שורה יחידה (id = default) */
model AdSettings {
  id                String   @id @default("default")
  zoneBanner        String?  @db.VarChar(64)
  zoneSidebar       String?  @db.VarChar(64)
  zoneSidebar2      String?  @db.VarChar(64)
  zoneInline        String?  @db.VarChar(64)
  popunderScriptUrl String?  @db.VarChar(512)
  nativeScriptUrl   String?  @db.VarChar(512)
  nativeContainerId String?  @db.VarChar(128)
  invokeHost        String?  @default("www.highperformanceformat.com") @db.VarChar(128)
  hilltopBannerScriptUrl   String?  @db.VarChar(512)
  hilltopSidebarScriptUrl  String?  @db.VarChar(512)
  hilltopMobileBannerScriptUrl String? @db.VarChar(512)
  hilltopPopunderUrl       String?  @db.VarChar(512)
  updatedAt         DateTime @default(now()) @updatedAt
}

/** הגדרות ניהול לכל כלי המרה (מזהה תואם ל־tools[].id בפרונט) */
model ToolConfig {
  toolId    String   @id
  enabled   Boolean  @default(true)
  featured  Boolean  @default(false)
  sortOrder Int      @default(0)
  notes     String?  @db.VarChar(500)
  updatedAt DateTime @updatedAt
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

enum BillingProvider {
  PAYPAL
  GOOGLE_PLAY
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  UNPAID
}

model Subscription {
  id                      String             @id @default(uuid())
  userId                  String             @unique
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentProvider         PaymentProvider    @default(PAYPAL)
  billingProvider         BillingProvider    @default(PAYPAL)
  stripeCustomerId        String?
  stripeSubscriptionId    String?            @unique
  paypalSubscriptionId    String?            @unique
  googlePlayPurchaseToken String?            @db.VarChar(500)
  googlePlayProductId     String?
  googlePlayOrderId       String?            @unique
  plan                    SubscriptionPlan
  status                  SubscriptionStatus @default(ACTIVE)
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean            @default(false)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([stripeCustomerId])
  @@index([paypalSubscriptionId])
  @@index([googlePlayProductId])
}

enum PaymentType {
  SUBSCRIPTION
  CREDITS
}

enum PaymentStatus {
  SUCCEEDED
  PENDING
  FAILED
}

model Payment {
  id                    String          @id @default(uuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingProvider       BillingProvider @default(PAYPAL)
  stripePaymentIntentId String?         @unique
  paypalTransactionId   String?         @unique
  googlePlayOrderId     String?         @unique
  amount                Int // in smallest currency unit (agorot/cents)
  currency              String          @default("ils")
  type                  PaymentType
  status                PaymentStatus   @default(SUCCEEDED)
  metadata              Json?
  createdAt             DateTime        @default(now())
}

model AiCredit {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance            Int       @default(0)
  monthlyCredits     Int       @default(0) // resets each billing cycle
  lifetimePurchased  Int       @default(0)
  lastMonthlyReset   DateTime?
  updatedAt          DateTime  @updatedAt
}

/** הגדרות AI — שורה יחידה (id = default); מפתח Google נשמר בשרת בלבד */
model AiSettings {
  id           String   @id @default("default")
  googleApiKey String?  @db.VarChar(256)
  modelName    String   @default("imagen-3.0-generate-002") @db.VarChar(128)
  enabled      Boolean  @default(false)
  updatedAt    DateTime @default(now()) @updatedAt
}

/** הגדרות אפליקציה גלובליות — שורה יחידה (id = default) */
model AppSettings {
  id                        String    @id @default("default")
  /** מוגדל בכל "הצג מבצע מחדש לכולם" — לקוחות עם generation נמוך יותר רואים שוב אונבורדינג */
  onboardingOfferGeneration Int       @default(0)
  onboardingRepromptedAt    DateTime?
  updatedAt                 DateTime  @default(now()) @updatedAt
}

enum AiGenerationStatus {
  SUCCESS
  FAILED
}

/** יומן עלות לכל ניסיון יצירת תמונה AI (הצלחה או כישלון) */
model AiGenerationLog {
  id               String             @id @default(uuid())
  userId           String?
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  toolId           String
  status           AiGenerationStatus
  creditsCharged   Int                @default(0)
  estimatedCostUsd Decimal?           @db.Decimal(10, 6)
  provider         String             @default("google") @db.VarChar(32)
  model            String?            @db.VarChar(128)
  promptPreview    String?            @db.VarChar(200)
  errorMessage     String?            @db.Text
  durationMs       Int?
  createdAt        DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([status, createdAt])
}

model UsageLog {
  id               String   @id @default(uuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId        String? // for anonymous users
  toolId           String
  fromFormat       String?
  toFormat         String?
  fileSizeBytes    BigInt?
  processingTimeMs Int?
  isPremium        Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ConversionJob {
  id                String    @id @default(uuid())
  userId            String?
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  toolId            String
  status            JobStatus @default(PENDING)
  inputStoragePath  String?
  outputStoragePath String?
  fromFormat        String
  toFormat          String
  fileSizeBytes     BigInt?
  errorMessage      String?  @db.Text
  priority          Boolean   @default(false) // premium users get priority
  createdAt         DateTime  @default(now())
  completedAt       DateTime?
}
