# Copy to keystore.properties (never commit keystore.properties or *.keystore).
# Generate keystore:
#   keytool -genkey -v -keystore tamir-release.keystore -alias tamir -keyalg RSA -keysize 2048 -validity 10000
#
# Then get SHA-256 for assetlinks.json:
#   keytool -list -v -keystore tamir-release.keystore -alias tamir

storeFile=../tamir-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=tamir
keyPassword=YOUR_KEY_PASSWORD
