FROM node:22-alpine AS frontend-build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG VITE_SITE_ORIGIN=https://tamir.li
ARG VITE_API_URL=https://tamir.li
ARG VITE_GOOGLE_CLIENT_ID=
ARG VITE_GTM_ID=
ARG VITE_ADSENSE_CLIENT=
ARG VITE_ADSENSE_SLOT_BANNER=
ARG VITE_ADSENSE_SLOT_SIDEBAR=
ARG VITE_ADSENSE_SLOT_INLINE=
ARG VITE_STRIPE_PUBLISHABLE_KEY=

ENV VITE_SITE_ORIGIN=$VITE_SITE_ORIGIN
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ENV VITE_GTM_ID=$VITE_GTM_ID
ENV VITE_ADSENSE_CLIENT=$VITE_ADSENSE_CLIENT
ENV VITE_ADSENSE_SLOT_BANNER=$VITE_ADSENSE_SLOT_BANNER
ENV VITE_ADSENSE_SLOT_SIDEBAR=$VITE_ADSENSE_SLOT_SIDEBAR
ENV VITE_ADSENSE_SLOT_INLINE=$VITE_ADSENSE_SLOT_INLINE
ENV VITE_STRIPE_PUBLISHABLE_KEY=$VITE_STRIPE_PUBLISHABLE_KEY

RUN npm run build:prod

FROM nginx:1.27-alpine

COPY docker/nginx/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=frontend-build /app/dist /usr/share/nginx/html

EXPOSE 80
