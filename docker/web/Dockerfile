FROM node:22-alpine AS frontend-build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG VITE_SITE_ORIGIN=https://tamir.li
ARG VITE_API_URL=https://tamir.li
ARG VITE_GOOGLE_CLIENT_ID=
ARG VITE_GTM_ID=
ARG VITE_ADSTERRA_ZONE_BANNER=
ARG VITE_ADSTERRA_ZONE_SIDEBAR=
ARG VITE_ADSTERRA_ZONE_SIDEBAR_2=
ARG VITE_ADSTERRA_ZONE_INLINE=
ARG VITE_ADSTERRA_POPUNDER_SCRIPT_URL=
ARG VITE_ADSTERRA_INVOKE_HOST=
ARG VITE_STRIPE_PUBLISHABLE_KEY=

ENV VITE_SITE_ORIGIN=$VITE_SITE_ORIGIN
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ENV VITE_GTM_ID=$VITE_GTM_ID
ENV VITE_ADSTERRA_ZONE_BANNER=$VITE_ADSTERRA_ZONE_BANNER
ENV VITE_ADSTERRA_ZONE_SIDEBAR=$VITE_ADSTERRA_ZONE_SIDEBAR
ENV VITE_ADSTERRA_ZONE_SIDEBAR_2=$VITE_ADSTERRA_ZONE_SIDEBAR_2
ENV VITE_ADSTERRA_ZONE_INLINE=$VITE_ADSTERRA_ZONE_INLINE
ENV VITE_ADSTERRA_POPUNDER_SCRIPT_URL=$VITE_ADSTERRA_POPUNDER_SCRIPT_URL
ENV VITE_ADSTERRA_INVOKE_HOST=$VITE_ADSTERRA_INVOKE_HOST
ENV VITE_STRIPE_PUBLISHABLE_KEY=$VITE_STRIPE_PUBLISHABLE_KEY

RUN npm run build:prod

FROM nginx:1.27-alpine

COPY docker/nginx/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=frontend-build /app/dist /usr/share/nginx/html

EXPOSE 80
