# Copy to `.env.docker` on the Plesk server (never commit secrets).
# Usage: docker compose --env-file .env.docker up -d --build

# --- Host port (Plesk proxy or Docker extension maps tamir.li → this port) ---
WEB_PORT=8080

# --- MySQL (container `mysql`) ---
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=tamirly_db
MYSQL_USER=tamirly
MYSQL_PASSWORD=change_me_db_password

# --- Backend (see also backend/.env.example) ---
JWT_SECRET=change_me_min_16_characters
GOOGLE_CLIENT_ID=
CORS_ORIGIN=https://tamir.li,https://www.tamir.li
ADMIN_EMAILS=you@example.com

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_CREDITS_10=
STRIPE_PRICE_CREDITS_30=
STRIPE_PRICE_CREDITS_60=
STRIPE_PRICE_CREDITS_120=

OPENAI_API_KEY=
RESEND_API_KEY=

# --- Frontend build args (baked into `web` image at build time) ---
# Same origin: API is proxied at /api on tamir.li (no api.tamir.li subdomain required).
VITE_SITE_ORIGIN=https://tamir.li
VITE_API_URL=https://tamir.li
VITE_GOOGLE_CLIENT_ID=
VITE_GTM_ID=
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT_BANNER=
VITE_ADSENSE_SLOT_SIDEBAR=
VITE_ADSENSE_SLOT_INLINE=
VITE_STRIPE_PUBLISHABLE_KEY=
